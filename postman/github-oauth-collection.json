      "name": "Auth",
      "item": [
        {
          "name": "Authenticated User - Valid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function(){\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains 'login' field\", function(){\r",
                  "    pm.expect(response).to.have.property(\"login\")\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Login matches expected username\", function(){\r",
                  "    pm.expect(response.login).to.eql(\"haris-yousaf\")\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains 'id' field\", function(){\r",
                  "    pm.expect(response).to.have.property(\"id\")\r",
                  "    pm.expect(response.id).to.be.a(\"number\")\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response contains 'type' field\", function(){\r",
                  "    pm.expect(response).to.have.property(\"type\")\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
